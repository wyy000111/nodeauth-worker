# 本地开发环境变量配置实例,请根据实际情况修改,获取方式请参照项目README.md

# [必填]系统安全参数
JWT_SECRET=YKPc4G****  # 必须32位以上
ENCRYPTION_KEY=U6p5y95OKkK**** # 必须32位以上

# [必填]Cloudflare D1 数据库参数
CLOUDFLARE_ACCOUNT_ID=fbce5f4***
CLOUDFLARE_API_TOKEN=yx5fupqCxK****

# [必填]Cloudflare 资源授权
CLOUDFLARE_D1_DATABASE_ID=9e591736-****
CLOUDFLARE_D1_DATABASE_NAME=nodeauth-db-dev

# [必填]登录白名单，支持用户名和邮箱，多个用","分隔
OAUTH_ALLOWED_USERS=abc,abc@gmail.com

#必填：OAuth 身份信息 (按需选择对应的组合)，必选一种方式，建议github

# Google
# OAUTH_GOOGLE_CLIENT_ID=3572****-5tdsrdp*****.apps.googleusercontent.com
# OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-GeCJsHC****
# OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8787/oauth/callback
# Google 备份源
# OAUTH_GOOGLE_BACKUP_REDIRECT_URI=http://localhost:8787/api/backups/oauth/google/callback

# Github
OAUTH_GITHUB_CLIENT_ID=Ov23liIt****
OAUTH_GITHUB_CLIENT_SECRET=cd6de****
OAUTH_GITHUB_REDIRECT_URI=http://localhost:8787/oauth/callback

